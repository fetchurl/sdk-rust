#!/usr/bin/env bash
set -euo pipefail

# Usage: ./make_release [next|major|minor|patch|<x.y.z>]
MODE="${1:-next}"

case "$MODE" in
  next|major|minor|patch)
    VERSION="$(svu "$MODE")"
    ;;
  *)
    VERSION="${MODE#v}"
    ;;
esac
VERSION="${VERSION#v}"

sed -i "0,/^version = /s//version = \"$VERSION\"/" Cargo.toml

git add Cargo.toml
git commit -sm "bump to $VERSION" || true
if [[ ! -v NO_TAG ]]; then
  git tag "$VERSION"
  git push origin "$VERSION"
fi
git push origin HEAD

echo "$VERSION"
